{
  "name": "foodsera-backend",
  "version": "1.0.0",
  "description": "Backend for Foodsera food delivery application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"npm run dev:auth\" \"npm run dev:restaurant\" \"npm run dev:order\" \"npm run dev:payment\" \"npm run dev:delivery\" \"npm run dev:admin\" \"npm run dev:notification\"",
    "dev:auth": "nodemon services/auth/server.js",
    "dev:restaurant": "nodemon services/restaurant/server.js",
    "dev:order": "nodemon services/order/server.js",
    "dev:payment": "nodemon services/payment/server.js",
    "dev:delivery": "nodemon services/delivery/server.js",
    "dev:admin": "nodemon services/admin/server.js",
    "dev:notification": "nodemon services/notification/server.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "firebase": "^10.5.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.3",
    "multer": "^1.4.5-lts.1",
    "stripe": "^13.10.0",
    "twilio": "^5.5.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "nodemon": "^3.0.1"
  }
}
